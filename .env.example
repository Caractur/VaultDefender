# Auth0 — Regular Web Application
AUTH0_SECRET=use-openssl-rand-hex-32-to-generate
AUTH0_BASE_URL=http://localhost:3000
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret

# Auth0 — Custom API audience (identifier you registered under Applications > APIs)
AUTH0_AUDIENCE=https://vaultdefender.example.com/api

# Auth0 — Token Vault (Custom API Client credentials for token exchange)
AUTH0_TOKEN_VAULT_CLIENT_ID=your-custom-api-client-id
AUTH0_TOKEN_VAULT_CLIENT_SECRET=your-custom-api-client-secret

# OpenRouter (for AI agent — get a key at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Chat agent (optional overrides)
# CHAT_MODEL=openai/gpt-4o-mini
# MAX_AGENT_STEPS=5

# Database
DATABASE_URL=file:./dev.db
